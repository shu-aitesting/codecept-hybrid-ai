# Environment selector: dev | staging | prod
ENV=dev

# Test target URLs
BASE_URL=http://localhost:3000
API_URL=http://localhost:3000/api

# Browser config
BROWSER=chromium
HEADLESS=false

# Test credentials (override per env)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# === API ambient headers ===
# Sent on EVERY request via Playwright extraHTTPHeaders.
# Generated services must NOT emit .header() for these — RestClient injects them automatically.
# Leave API_TOKEN empty for unauthenticated APIs.

# Token value (required when API needs auth)
API_TOKEN=

# Language and timezone (only injected when non-empty)
API_LANGUAGE=vi-VN
API_TIMEZONE=Asia/Ho_Chi_Minh

# === Ambient header names (optional — change only when your API uses non-default names) ===
#
# Preset A — Default ecosystem (raw token, no "Bearer " prefix):
# API_HEADER_TOKEN=Token              # default
# API_HEADER_TOKEN_PREFIX=            # default: empty (raw)
# API_HEADER_LANGUAGE=Lng             # default
# API_HEADER_TIMEZONE=Tz              # default
#
# Preset B — HTTP standard Bearer (uncomment to switch):
# API_HEADER_TOKEN=Authorization
# API_HEADER_TOKEN_PREFIX=Bearer
#
# Preset C — Custom API key header (e.g. AWS-style):
# API_HEADER_TOKEN=X-API-Key
# API_HEADER_TOKEN_PREFIX=

# AI Providers (Step 11+)
ANTHROPIC_API_KEY=
COHERE_API_KEY=
HF_TOKEN=
AI_HEAL_ENABLED=false
MAX_DAILY_BUDGET_USD=5

# Reporting
ALLURE_RESULTS_DIR=./output/reports/allure

# Logging
LOG_LEVEL=info
