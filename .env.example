# Environment selector: dev | staging | prod
ENV=dev

# Test target URLs
BASE_URL=http://localhost:3000
API_URL=http://localhost:3000/api

# Browser config
BROWSER=chromium
HEADLESS=false

# Test credentials (override per env)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# API ambient headers — sent on EVERY request via Playwright extraHTTPHeaders.
# Generated services should NOT emit .header() for these three; the RestClient injects them.
# Leave API_TOKEN empty when the API is unauthenticated.
API_TOKEN=
API_LANGUAGE=en-US
API_TIMEZONE=Asia/Ho_Chi_Minh

# AI Providers (Step 11+)
ANTHROPIC_API_KEY=
COHERE_API_KEY=
HF_TOKEN=
AI_HEAL_ENABLED=false
MAX_DAILY_BUDGET_USD=5

# Reporting
ALLURE_RESULTS_DIR=./output/reports/allure

# Logging
LOG_LEVEL=info
