{
  "swagger": "2.0",
  "info": {
    "title": "Petstore",
    "version": "1.0.0",
    "description": "Minimal Swagger 2.0 fixture for unit tests"
  },
  "host": "petstore.example.com",
  "basePath": "/v2",
  "schemes": ["https"],
  "paths": {
    "/pets": {
      "get": {
        "operationId": "listPets",
        "summary": "List all pets",
        "tags": ["pets"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "type": "integer",
            "description": "Max number of results"
          }
        ],
        "responses": {
          "200": {
            "description": "A list of pets",
            "schema": { "$ref": "#/definitions/PetList" }
          }
        }
      },
      "post": {
        "operationId": "createPet",
        "summary": "Create a pet",
        "tags": ["pets"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/NewPet" }
          }
        ],
        "responses": {
          "201": { "description": "Created", "schema": { "$ref": "#/definitions/Pet" } }
        }
      }
    },
    "/pets/{id}": {
      "get": {
        "operationId": "getPetById",
        "summary": "Get a pet by ID",
        "tags": ["pets"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "type": "integer" }],
        "responses": {
          "200": { "description": "A single pet", "schema": { "$ref": "#/definitions/Pet" } },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "operationId": "deletePet",
        "summary": "Delete a pet",
        "tags": ["pets"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "type": "integer" }],
        "responses": {
          "204": { "description": "Deleted" }
        }
      }
    },
    "/tags": {
      "get": {
        "operationId": "listTags",
        "summary": "List all tags",
        "tags": ["tags"],
        "responses": {
          "200": {
            "description": "A list of tags",
            "schema": { "$ref": "#/definitions/TagList" }
          }
        }
      }
    }
  },
  "definitions": {
    "Category": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" }
      }
    },
    "Tag": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" }
      }
    },
    "TagList": {
      "type": "array",
      "items": { "$ref": "#/definitions/Tag" }
    },
    "Pet": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "pending", "sold"] },
        "category": { "$ref": "#/definitions/Category" },
        "tags": { "type": "array", "items": { "$ref": "#/definitions/Tag" } }
      }
    },
    "PetList": {
      "type": "array",
      "items": { "$ref": "#/definitions/Pet" }
    },
    "NewPet": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "pending", "sold"] }
      }
    }
  }
}
