{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": "./src",
    "paths": {
      "@core/*": ["core/*"],
      "@api/*": ["api/*"],
      "@ui/*": ["ui/*"],
      "@ai/*": ["ai/*"],
      "@visual/*": ["visual/*"],
      "@fixtures/*": ["fixtures/*"],
      "@hooks/*": ["hooks/*"]
    },
    "outDir": "./dist",
    "types": ["node", "codeceptjs"]
  },
  "include": ["src/**/*", "tests/**/*", "config/**/*", "scripts/**/*", "*.ts", "*.d.ts"],
  "exclude": ["node_modules", "dist", "output"],
  "ts-node": {
    "files": true
  }
}
